#!/usr/bin/env bash
# update - Switch NixOS + Home Manager, with optional flake-input refresh.
#
# System layer: `sudo nixos-rebuild switch` (direct; covered by the
#   passwordless sudo rule in nixos/profiles/shared.nix).
# User layer:   `nh home switch` (no sudo needed; nh's TUI/diff is kept here).
#
# We intentionally do NOT use `nh os switch` for the system layer:
# nh always wraps the activation in `sudo env … switch-to-configuration`,
# which can't be safely scoped in sudoers (allowing `sudo env` is
# equivalent to full root). Calling `nixos-rebuild` directly lets the
# narrow allowlist (just nixos-rebuild + nix) actually work.
#
# Flags:
#   -u, --update    Refresh flake inputs (both layers, in parallel) before switching.
#   -h, --help      Show this help.
#
# Firmware updates live in `firmware-update` (separate script — interactive sudo).
set -euo pipefail

UPDATE_INPUTS=0
for arg in "$@"; do
  case "$arg" in
  -u | --update) UPDATE_INPUTS=1 ;;
  -h | --help)
    sed -n '/^# update -/,/^[^#]/p' "$0" | sed -e '$d' -e 's/^# \?//'
    exit 0
    ;;
  *)
    echo "update: unknown flag: $arg" >&2
    exit 2
    ;;
  esac
done

red() {
  tput setaf 1 2>/dev/null || true
  echo -e "\n$*\033[0m"
}

command -v nh >/dev/null || {
  echo "update: nh not found on PATH (expected pkgs.nh from home-manager)." >&2
  exit 1
}

# Authenticate flake fetches against GitHub to avoid the 60 req/hr
# unauthenticated API limit. `gh auth token` reuses the existing gh login;
# falls back to no-op if gh is unavailable.
GH_TOKEN_ARGS=()
if command -v gh >/dev/null && GH_TOKEN="$(gh auth token 2>/dev/null)" && [ -n "$GH_TOKEN" ]; then
  GH_TOKEN_ARGS=(--access-tokens "github.com=$GH_TOKEN")
fi

if [ "$UPDATE_INPUTS" = 1 ]; then
  red "Refreshing flake inputs [system + user] in parallel..."
  sudo nix flake update "${GH_TOKEN_ARGS[@]}" --flake /etc/nixos &
  SYS_UPD_PID=$!
  nix flake update "${GH_TOKEN_ARGS[@]}" --flake "$HOME/.config/home-manager" &
  HM_UPD_PID=$!
  status=0
  wait "$SYS_UPD_PID" || status=1
  wait "$HM_UPD_PID" || status=1
  if [ "$status" -ne 0 ]; then
    echo "update: one or more flake updates failed" >&2
    exit 1
  fi
fi

red "Switching system layer (nixos-rebuild)..."
sudo nixos-rebuild switch --flake /etc/nixos

red "Switching user layer via nh..."
nh home switch "$HOME/.config/home-manager" -c nelson

red "Done."
