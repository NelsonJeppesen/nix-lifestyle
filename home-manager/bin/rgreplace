#!/usr/bin/env bash
# rgreplace: bulk regex replacement using ripgrep and sd.
# Usage: rgreplace <search> <replace> [path]
#
# Both tools use Rust regex syntax. Capture replacements use `$1`, `$2`, etc.
set -euo pipefail

usage() {
  cat <<'EOF'
rgreplace -- bulk regex search-and-replace across files

Usage: rgreplace <search> <replace> [path]

  <search>   Rust regex pattern.
  <replace>  Replacement string. Captures use $1, $2, etc.
  [path]     Directory or file to recurse into. Defaults to '.'.

Options:
  -h, --help    Show this help message.

Examples:
  rgreplace 'foo' 'bar' src/
  rgreplace '\bcolour\b' 'color'
EOF
}

case "${1-}" in
-h | --help)
  usage
  exit 0
  ;;
esac

if [ "$#" -lt 2 ]; then
  usage >&2
  exit 64
fi

search=$1
replace=$2
target=${3:-.}

rg -l -0 -- "$search" "$target" |
  xargs -0 -r -n1 sd "$search" "$replace"
