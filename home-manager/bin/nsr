#!/usr/bin/env bash
# nsr: run a command from a transient Nix shell.
# Usage: nsr <package> [command...]
# If [command] is omitted the package name is reused as the command.
# Examples:
#   nsr jq                        # runs `jq` (no args)
#   nsr jq jq -r .foo data.json   # runs `jq -r .foo data.json` inside the shell
set -euo pipefail

usage() {
  cat <<'EOF'
nsr -- Nix Shell Run

Usage: nsr <package> [command...]

If [command] is omitted, the package name is reused as the command.

Options:
  -h, --help    Show this help message.
EOF
}

case "${1-}" in
-h | --help)
  usage
  exit 0
  ;;
esac

if [ "$#" -lt 1 ]; then
  usage >&2
  exit 64
fi

pkg=$1
shift
if [ "$#" -eq 0 ]; then
  set -- "$pkg"
fi

set -x
exec nix shell "nixpkgs#$pkg" --command "$@"
